<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Menu Bar -->
    <folder name="Menu">
        <folder name="Tools">
            <file name="org-flossware-netbeans-chatgpt-ChatGPTAction.shadow">
                <attr name="originalFile" stringvalue="Actions/Tools/org-flossware-netbeans-chatgpt-ChatGPTAction.instance"/>
                <attr name="position" intvalue="1000"/>
            </file>
        </folder>
    </folder>

    <!-- Actions -->
    <folder name="Actions">
        <folder name="Tools">
            <file name="org-flossware-netbeans-chatgpt-ChatGPTAction.instance">
                <attr name="instanceCreate" methodvalue="org.openide.awt.Actions.alwaysEnabled"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.chatgpt.Bundle#CTL_ChatGPTAction"/>
                <attr name="iconBase" stringvalue="org/flossware/netbeans/chatgpt/resources/chatgpt-icon.png"/>
            </file>
        </folder>
        <folder name="Window">
            <file name="org-flossware-netbeans-chatgpt-ChatGPTWindowAction.instance">
                <attr name="component" methodvalue="org.flossware.netbeans.chatgpt.ui.ChatGPTWindowTopComponent.findInstance"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.chatgpt.Bundle#CTL_ChatGPTWindowAction"/>
                <attr name="iconBase" stringvalue="org/flossware/netbeans/chatgpt/resources/chatgpt-icon.png"/>
                <attr name="instanceCreate" methodvalue="org.openide.windows.TopComponent.openAction"/>
            </file>
        </folder>
    </folder>

    <!-- Window -->
    <folder name="Windows2">
        <folder name="Components">
            <file name="ChatGPTWindowTopComponent.settings" url="ChatGPTWindowTopComponentSettings.xml"/>
        </folder>
        <folder name="Modes">
            <folder name="rightSlidingSide">
                <file name="ChatGPTWindowTopComponent.wstcref" url="ChatGPTWindowTopComponentWstcref.xml"/>
            </folder>
        </folder>
    </folder>
</filesystem>
