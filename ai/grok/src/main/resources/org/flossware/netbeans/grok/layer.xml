<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Menu Bar -->
    <folder name="Menu">
        <folder name="Tools">
            <file name="org-flossware-netbeans-grok-GrokAction.shadow">
                <attr name="originalFile" stringvalue="Actions/Tools/org-flossware-netbeans-grok-GrokAction.instance"/>
                <attr name="position" intvalue="1001"/>
            </file>
        </folder>
    </folder>

    <!-- Actions -->
    <folder name="Actions">
        <folder name="Tools">
            <file name="org-flossware-netbeans-grok-GrokAction.instance">
                <attr name="instanceCreate" methodvalue="org.openide.awt.Actions.alwaysEnabled"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.grok.Bundle#CTL_GrokAction"/>
                <attr name="iconBase" stringvalue="org/flossware/netbeans/grok/resources/grok-icon.png"/>
            </file>
        </folder>
        <folder name="Window">
            <file name="org-flossware-netbeans-grok-GrokWindowAction.instance">
                <attr name="component" methodvalue="org.flossware.netbeans.grok.ui.GrokWindowTopComponent.findInstance"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.grok.Bundle#CTL_GrokWindowAction"/>
                <attr name="iconBase" stringvalue="org/flossware/netbeans/grok/resources/grok-icon.png"/>
                <attr name="instanceCreate" methodvalue="org.openide.windows.TopComponent.openAction"/>
            </file>
        </folder>
    </folder>

    <!-- Window -->
    <folder name="Windows2">
        <folder name="Components">
            <file name="GrokWindowTopComponent.settings" url="GrokWindowTopComponentSettings.xml"/>
        </folder>
        <folder name="Modes">
            <folder name="rightSlidingSide">
                <file name="GrokWindowTopComponent.wstcref" url="GrokWindowTopComponentWstcref.xml"/>
            </folder>
        </folder>
    </folder>
</filesystem>
