<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Menu Bar -->
    <folder name="Menu">
        <folder name="Tools">
            <file name="org-flossware-netbeans-claude-ClaudeAction.shadow">
                <attr name="originalFile" stringvalue="Actions/Tools/org-flossware-netbeans-claude-ClaudeAction.instance"/>
                <attr name="position" intvalue="1000"/>
            </file>
        </folder>
    </folder>

    <!-- Actions -->
    <folder name="Actions">
        <folder name="Tools">
            <file name="org-flossware-netbeans-claude-ClaudeAction.instance">
                <attr name="instanceCreate" methodvalue="org.openide.awt.Actions.alwaysEnabled"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.claude.Bundle#CTL_ClaudeAction"/>
                <attr name="iconBase" stringvalue="org/flossware/netbeans/claude/resources/claude-icon.png"/>
            </file>
        </folder>
        <folder name="Window">
            <file name="org-flossware-netbeans-claude-ClaudeWindowAction.instance">
                <attr name="component" methodvalue="org.flossware.netbeans.claude.ui.ClaudeWindowTopComponent.findInstance"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.claude.Bundle#CTL_ClaudeWindowAction"/>
                <attr name="iconBase" stringvalue="org/flossware/netbeans/claude/resources/claude-icon.png"/>
                <attr name="instanceCreate" methodvalue="org.openide.windows.TopComponent.openAction"/>
            </file>
        </folder>
    </folder>

    <!-- Window -->
    <folder name="Windows2">
        <folder name="Components">
            <file name="ClaudeWindowTopComponent.settings" url="ClaudeWindowTopComponentSettings.xml"/>
        </folder>
        <folder name="Modes">
            <folder name="rightSlidingSide">
                <file name="ClaudeWindowTopComponent.wstcref" url="ClaudeWindowTopComponentWstcref.xml"/>
            </folder>
        </folder>
    </folder>
</filesystem>
