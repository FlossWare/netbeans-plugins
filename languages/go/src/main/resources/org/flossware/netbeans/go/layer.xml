<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Go MIME type -->
    <folder name="Loaders">
        <folder name="text">
            <folder name="x-go">
                <folder name="Actions">
                    <file name="org-flossware-netbeans-go-execution-RunGoAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/Go/org-flossware-netbeans-go-execution-RunGoAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Editor Popup Menu -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-go">
                <folder name="Popup">
                    <file name="org-flossware-netbeans-go-execution-RunGoAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/Go/org-flossware-netbeans-go-execution-RunGoAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Actions -->
    <folder name="Actions">
        <folder name="Go">
            <file name="org-flossware-netbeans-go-execution-RunGoAction.instance">
                <attr name="instanceCreate" methodvalue="org.openide.awt.Actions.alwaysEnabled"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.go.Bundle#CTL_RunGoAction"/>
            </file>
        </folder>
        <folder name="Debug">
            <file name="org-flossware-netbeans-go-debugger-DebugGoAction.instance">
                <attr name="instanceCreate" methodvalue="org.flossware.netbeans.go.debugger.DebugGoAction.create"/>
            </file>
        </folder>
    </folder>

    <!-- Menu -->
    <folder name="Menu">
        <folder name="Window">
            <file name="org-flossware-netbeans-go-ui-GoConsoleTopComponent.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-flossware-netbeans-go-ui-GoConsoleTopComponent.instance"/>
                <attr name="position" intvalue="334"/>
            </file>
        </folder>
    </folder>

    <!-- Services -->
    <folder name="Services">
        <folder name="MIMEResolver">
            <file name="GoResolver.xml" url="GoResolver.xml">
                <attr name="displayName" bundlevalue="org.flossware.netbeans.go.Bundle#Services/MIMEResolver/GoResolver.xml"/>
            </file>
        </folder>
    </folder>

    <!-- Language Registration -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-go">
                <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.go.Bundle"/>
                <file name="language.instance">
                    <attr name="instanceOf" stringvalue="org.netbeans.api.lexer.Language"/>
                    <attr name="instanceCreate" methodvalue="org.flossware.netbeans.go.lexer.GoTokenId.language"/>
                </file>
                <file name="FontsColors.xml" url="FontsColors.xml">
                    <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.go.Bundle"/>
                </file>
            </folder>
        </folder>
    </folder>
</filesystem>
