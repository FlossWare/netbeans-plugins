<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- MIME Resolver for Groovy files -->
    <folder name="Services">
        <folder name="MIMEResolver">
            <file name="GroovyResolver.xml" url="GroovyResolver.xml">
                <attr name="displayName" bundlevalue="org.flossware.netbeans.groovy.Bundle#text/x-groovy"/>
            </file>
        </folder>
    </folder>

    <!-- Editors -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-groovy">
                <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.groovy.Bundle"/>

                <!-- Language Registration -->
                <file name="language.instance">
                    <attr name="instanceOf" stringvalue="org.netbeans.api.lexer.Language"/>
                    <attr name="instanceCreate" methodvalue="org.flossware.netbeans.groovy.lexer.GroovyTokenId.language"/>
                </file>
                <file name="FontsColors.xml" url="FontsColors.xml">
                    <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.groovy.Bundle"/>
                </file>

                <!-- Code Completion -->
                <folder name="CompletionProviders">
                    <file name="org-flossware-netbeans-groovy-completion-GroovyLspCompletionProvider.instance"/>
                </folder>

                <!-- Context Menu Actions -->
                <folder name="Actions">
                    <file name="org-flossware-netbeans-groovy-execution-RunGroovyAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/Run/org-flossware-netbeans-groovy-execution-RunGroovyAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Loaders -->
    <folder name="Loaders">
        <folder name="text">
            <folder name="x-groovy">
                <folder name="Actions">
                    <file name="org-flossware-netbeans-groovy-execution-RunGroovyAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/Run/org-flossware-netbeans-groovy-execution-RunGroovyAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                    <file name="org-openide-actions-OpenAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/System/org-openide-actions-OpenAction.instance"/>
                        <attr name="position" intvalue="200"/>
                    </file>
                    <file name="org-openide-actions-FileSystemAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/System/org-openide-actions-FileSystemAction.instance"/>
                        <attr name="position" intvalue="300"/>
                    </file>
                    <file name="org-openide-actions-ToolsAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/System/org-openide-actions-ToolsAction.instance"/>
                        <attr name="position" intvalue="400"/>
                    </file>
                    <file name="org-openide-actions-PropertiesAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/System/org-openide-actions-PropertiesAction.instance"/>
                        <attr name="position" intvalue="500"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Actions -->
    <folder name="Actions">
        <folder name="Run">
            <file name="org-flossware-netbeans-groovy-execution-RunGroovyAction.instance">
                <attr name="instanceCreate" methodvalue="org.flossware.netbeans.groovy.execution.RunGroovyAction.create"/>
            </file>
        </folder>
        <folder name="Debug">
            <file name="org-flossware-netbeans-groovy-debugger-DebugGroovyAction.instance">
                <attr name="instanceCreate" methodvalue="org.flossware.netbeans.groovy.debugger.DebugGroovyAction.create"/>
            </file>
        </folder>
        <folder name="Window">
            <file name="org-flossware-netbeans-groovy-ui-GroovyConsoleTopComponent.instance">
                <attr name="component" methodvalue="org.flossware.netbeans.groovy.ui.GroovyConsoleTopComponent.create"/>
            </file>
        </folder>
    </folder>

    <!-- Menu -->
    <folder name="Menu">
        <folder name="Window">
            <file name="GroovyConsoleAction.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-flossware-netbeans-groovy-ui-GroovyConsoleTopComponent.instance"/>
                <attr name="position" intvalue="1000"/>
            </file>
        </folder>
    </folder>
</filesystem>
