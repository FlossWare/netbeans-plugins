<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- JavaScript MIME type -->
    <folder name="Loaders">
        <folder name="text">
            <folder name="x-javascript">
                <folder name="Actions">
                    <file name="org-flossware-netbeans-javascript-execution-RunJavaScriptAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/JavaScript/org-flossware-netbeans-javascript-execution-RunJavaScriptAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Editor Popup Menu -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-javascript">
                <folder name="Popup">
                    <file name="org-flossware-netbeans-javascript-execution-RunJavaScriptAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/JavaScript/org-flossware-netbeans-javascript-execution-RunJavaScriptAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Actions -->
    <folder name="Actions">
        <folder name="JavaScript">
            <file name="org-flossware-netbeans-javascript-execution-RunJavaScriptAction.instance">
                <attr name="instanceCreate" methodvalue="org.openide.awt.Actions.alwaysEnabled"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.javascript.Bundle#CTL_RunJavaScriptAction"/>
            </file>
        </folder>
        <folder name="Debug">
            <file name="org-flossware-netbeans-javascript-debugger-DebugJavaScriptAction.instance">
                <attr name="instanceCreate" methodvalue="org.flossware.netbeans.javascript.debugger.DebugJavaScriptAction.create"/>
            </file>
        </folder>
    </folder>

    <!-- Menu -->
    <folder name="Menu">
        <folder name="Window">
            <file name="org-flossware-netbeans-javascript-ui-JavaScriptConsoleTopComponent.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-flossware-netbeans-javascript-ui-JavaScriptConsoleTopComponent.instance"/>
                <attr name="position" intvalue="333"/>
            </file>
        </folder>
    </folder>

    <!-- Services -->
    <folder name="Services">
        <folder name="MIMEResolver">
            <file name="JavaScriptResolver.xml" url="JavaScriptResolver.xml">
                <attr name="displayName" bundlevalue="org.flossware.netbeans.javascript.Bundle#Services/MIMEResolver/JavaScriptResolver.xml"/>
            </file>
        </folder>
    </folder>

    <!-- Language Registration -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-javascript">
                <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.javascript.Bundle"/>
                <file name="language.instance">
                    <attr name="instanceOf" stringvalue="org.netbeans.api.lexer.Language"/>
                    <attr name="instanceCreate" methodvalue="org.flossware.netbeans.javascript.lexer.JavaScriptTokenId.language"/>
                </file>
                <file name="FontsColors.xml" url="FontsColors.xml">
                    <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.javascript.Bundle"/>
                </file>
            </folder>
        </folder>
    </folder>
</filesystem>
