<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Rust MIME type -->
    <folder name="Loaders">
        <folder name="text">
            <folder name="x-rust">
                <folder name="Actions">
                    <file name="org-flossware-netbeans-rust-execution-RunRustAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/Rust/org-flossware-netbeans-rust-execution-RunRustAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Editor Popup Menu -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-rust">
                <folder name="Popup">
                    <file name="org-flossware-netbeans-rust-execution-RunRustAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/Rust/org-flossware-netbeans-rust-execution-RunRustAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Actions -->
    <folder name="Actions">
        <folder name="Rust">
            <file name="org-flossware-netbeans-rust-execution-RunRustAction.instance">
                <attr name="instanceCreate" methodvalue="org.openide.awt.Actions.alwaysEnabled"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.rust.Bundle#CTL_RunRustAction"/>
            </file>
        </folder>
        <folder name="Debug">
            <file name="org-flossware-netbeans-rust-debugger-DebugRustAction.instance">
                <attr name="instanceCreate" methodvalue="org.flossware.netbeans.rust.debugger.DebugRustAction.create"/>
            </file>
        </folder>
    </folder>

    <!-- Menu -->
    <folder name="Menu">
        <folder name="Window">
            <file name="org-flossware-netbeans-rust-ui-RustConsoleTopComponent.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-flossware-netbeans-rust-ui-RustConsoleTopComponent.instance"/>
                <attr name="position" intvalue="334"/>
            </file>
        </folder>
    </folder>

    <!-- Services -->
    <folder name="Services">
        <folder name="MIMEResolver">
            <file name="RustResolver.xml" url="RustResolver.xml">
                <attr name="displayName" bundlevalue="org.flossware.netbeans.rust.Bundle#Services/MIMEResolver/RustResolver.xml"/>
            </file>
        </folder>
    </folder>

    <!-- Language Registration -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-rust">
                <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.rust.Bundle"/>
                <file name="language.instance">
                    <attr name="instanceOf" stringvalue="org.netbeans.api.lexer.Language"/>
                    <attr name="instanceCreate" methodvalue="org.flossware.netbeans.rust.lexer.RustTokenId.language"/>
                </file>
                <file name="FontsColors.xml" url="FontsColors.xml">
                    <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.rust.Bundle"/>
                </file>
            </folder>
        </folder>
    </folder>
</filesystem>
