<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- TypeScript MIME type -->
    <folder name="Loaders">
        <folder name="text">
            <folder name="x-typescript">
                <folder name="Actions">
                    <file name="org-flossware-netbeans-typescript-execution-RunTypeScriptAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/TypeScript/org-flossware-netbeans-typescript-execution-RunTypeScriptAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Editor Popup Menu -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-typescript">
                <folder name="Popup">
                    <file name="org-flossware-netbeans-typescript-execution-RunTypeScriptAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/TypeScript/org-flossware-netbeans-typescript-execution-RunTypeScriptAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Actions -->
    <folder name="Actions">
        <folder name="TypeScript">
            <file name="org-flossware-netbeans-typescript-execution-RunTypeScriptAction.instance">
                <attr name="instanceCreate" methodvalue="org.openide.awt.Actions.alwaysEnabled"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.typescript.Bundle#CTL_RunTypeScriptAction"/>
            </file>
        </folder>
        <folder name="Debug">
            <file name="org-flossware-netbeans-typescript-debugger-DebugTypeScriptAction.instance">
                <attr name="instanceCreate" methodvalue="org.flossware.netbeans.typescript.debugger.DebugTypeScriptAction.create"/>
            </file>
        </folder>
    </folder>

    <!-- Menu -->
    <folder name="Menu">
        <folder name="Window">
            <file name="org-flossware-netbeans-typescript-ui-TypeScriptConsoleTopComponent.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-flossware-netbeans-typescript-ui-TypeScriptConsoleTopComponent.instance"/>
                <attr name="position" intvalue="334"/>
            </file>
        </folder>
    </folder>

    <!-- Services -->
    <folder name="Services">
        <folder name="MIMEResolver">
            <file name="TypeScriptResolver.xml" url="TypeScriptResolver.xml">
                <attr name="displayName" bundlevalue="org.flossware.netbeans.typescript.Bundle#Services/MIMEResolver/TypeScriptResolver.xml"/>
            </file>
        </folder>
    </folder>

    <!-- Language Registration -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-typescript">
                <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.typescript.Bundle"/>
                <file name="language.instance">
                    <attr name="instanceOf" stringvalue="org.netbeans.api.lexer.Language"/>
                    <attr name="instanceCreate" methodvalue="org.flossware.netbeans.typescript.lexer.TypeScriptTokenId.language"/>
                </file>
                <file name="FontsColors.xml" url="FontsColors.xml">
                    <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.typescript.Bundle"/>
                </file>
            </folder>
        </folder>
    </folder>
</filesystem>
