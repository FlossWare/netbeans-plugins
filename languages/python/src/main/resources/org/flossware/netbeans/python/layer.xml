<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Python MIME type -->
    <folder name="Loaders">
        <folder name="text">
            <folder name="x-python">
                <folder name="Actions">
                    <file name="org-flossware-netbeans-python-execution-RunPythonAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/Python/org-flossware-netbeans-python-execution-RunPythonAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Editor Popup Menu -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-python">
                <folder name="Popup">
                    <file name="org-flossware-netbeans-python-execution-RunPythonAction.shadow">
                        <attr name="originalFile" stringvalue="Actions/Python/org-flossware-netbeans-python-execution-RunPythonAction.instance"/>
                        <attr name="position" intvalue="100"/>
                    </file>
                </folder>
            </folder>
        </folder>
    </folder>

    <!-- Actions -->
    <folder name="Actions">
        <folder name="Python">
            <file name="org-flossware-netbeans-python-execution-RunPythonAction.instance">
                <attr name="instanceCreate" methodvalue="org.openide.awt.Actions.alwaysEnabled"/>
                <attr name="displayName" bundlevalue="org.flossware.netbeans.python.Bundle#CTL_RunPythonAction"/>
            </file>
        </folder>
        <folder name="Debug">
            <file name="org-flossware-netbeans-python-debugger-DebugPythonAction.instance">
                <attr name="instanceCreate" methodvalue="org.flossware.netbeans.python.debugger.DebugPythonAction.create"/>
            </file>
        </folder>
    </folder>

    <!-- Menu -->
    <folder name="Menu">
        <folder name="Window">
            <file name="org-flossware-netbeans-python-ui-PythonConsoleTopComponent.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-flossware-netbeans-python-ui-PythonConsoleTopComponent.instance"/>
                <attr name="position" intvalue="333"/>
            </file>
        </folder>
    </folder>

    <!-- Services -->
    <folder name="Services">
        <folder name="MIMEResolver">
            <file name="PythonResolver.xml" url="PythonResolver.xml">
                <attr name="displayName" bundlevalue="org.flossware.netbeans.python.Bundle#Services/MIMEResolver/PythonResolver.xml"/>
            </file>
        </folder>
    </folder>

    <!-- Language Registration -->
    <folder name="Editors">
        <folder name="text">
            <folder name="x-python">
                <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.python.Bundle"/>
                <file name="language.instance">
                    <attr name="instanceOf" stringvalue="org.netbeans.api.lexer.Language"/>
                    <attr name="instanceCreate" methodvalue="org.flossware.netbeans.python.lexer.PythonTokenId.language"/>
                </file>
                <file name="FontsColors.xml" url="FontsColors.xml">
                    <attr name="SystemFileSystem.localizingBundle" stringvalue="org.flossware.netbeans.python.Bundle"/>
                </file>
            </folder>
        </folder>
    </folder>
</filesystem>
